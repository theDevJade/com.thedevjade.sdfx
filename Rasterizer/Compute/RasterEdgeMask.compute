#pragma kernel CSMain

Texture2D<float4> _SourceTex;
Texture2D<float> _EdgeTex;
RWTexture2D<float> _MaskTex;
uint _Width;
uint _Height;
float _EdgeThreshold;
float _MinAlpha;

[numthreads(8, 8, 1)]
void CSMain(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= _Width || id.y >= _Height)
    {
        return;
    }

    float4 c = _SourceTex[id.xy];
    float edge = _EdgeTex[id.xy];
    bool hit = c.a >= _MinAlpha && edge >= _EdgeThreshold;
    _MaskTex[id.xy] = hit ? 1.0 : 0.0;
}
